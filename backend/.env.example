# Backend environment variables
# -------------------------------
# Copy this file to `.env` and fill in real values to run in ONLINE mode.
# Leave it absent entirely to run OFFLINE (SQLite + no auth) — a fresh clone
# has no `.env`, so it's offline by default.
#
# NEVER commit your real `.env` (it's gitignored).

# Postgres / Supabase connection string. Presence of this var is what flips
# the backend into online mode (Postgres + Supabase auth).
# Prefer a least-privilege role over the postgres superuser (see README).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Optional but recommended. Supabase -> Settings -> API -> JWT Secret.
# When set, the backend verifies JWTs locally (fast, no network round-trip).
# If omitted, it falls back to validating each token via the Supabase API.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Optional. Origin allowed by CORS in online mode. Defaults to the deployed
# dashboard URL if unset. Set this for your own fork/preview domain.
FRONTEND_ORIGIN=https://your-dashboard.vercel.app
